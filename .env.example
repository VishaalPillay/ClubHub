# Copy to .env and fill in values. .env is git-ignored.
# DATABASE_URL uses the compose-network host `db` (see docs/adr/0003-execution-model.md).
# For optional host-side work, override to ...@localhost:5432/... in your shell.
DATABASE_URL=postgresql+psycopg://clubhub:clubhub@db:5432/clubhub

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Required: the app refuses to start if this is empty or the placeholder (unless DEBUG=true).
JWT_SECRET_KEY=

# Local/host test escape hatch only — bypasses the JWT-secret startup guard. Never in prod.
# DEBUG=true

# Refresh-token cookie: MUST be set true in any HTTPS deployment (see docs/adr/0002).
# Defaults to false so local http dev and the in-container test client work out of the box.
# COOKIE_SECURE=true

# Comma-separated list of allowed frontend origins (explicit — never "*" with credentials).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Google sign-in. Create an OAuth 2.0 Web client in Google Cloud Console and put its
# client ID here AND in the frontend's NEXT_PUBLIC_GOOGLE_CLIENT_ID (frontend/.env.local).
# POST /auth/google returns 503 GOOGLE_NOT_CONFIGURED (and the frontend hides the button)
# while the ID is empty. The client secret is unused by the ID-token flow; kept for later.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Media storage for avatar uploads: "local" (dev; served at /media) or "s3" (production).
# STORAGE_BACKEND=local
# MEDIA_ROOT=media
# MEDIA_BASE_URL=http://localhost:8000/media
# For s3: bucket must allow public reads (or front it with CloudFront via S3_PUBLIC_BASE_URL).
# S3_BUCKET=
# S3_REGION=
# S3_PUBLIC_BASE_URL=
# MAX_UPLOAD_MB=5
