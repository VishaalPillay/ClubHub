                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="s2-desc" value="&lt;div&gt;&lt;b&gt;Load the frontend&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;app.domain serves the Next.js 16 app (server-rendered) from AWS Amplify Hosting.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="s2-grp" vertex="1">
