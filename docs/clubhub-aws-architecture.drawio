                </mxCell>
                <mxCell id="s10-badge" value="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=20;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" parent="s10-grp" vertex="1">
                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
