                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="s4-desc" value="&lt;div&gt;&lt;b&gt;Reach the API container&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;ALB forwards to the ECS Fargate task (FastAPI :8000), chosen by the /health check.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="s4-grp" vertex="1">
