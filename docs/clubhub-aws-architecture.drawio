                <mxCell id="s7-desc" value="&lt;div&gt;&lt;b&gt;Store an avatar&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Uploads are processed to 512px WebP and written to the private S3 bucket.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="s7-grp" vertex="1">
