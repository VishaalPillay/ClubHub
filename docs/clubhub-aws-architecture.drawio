                <mxCell id="s1-desc" value="&lt;div&gt;&lt;b&gt;Member hits the app&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Browser makes an HTTPS request; Route 53 resolves app / api / media subdomains.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="s1-grp" vertex="1">
