                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="s3-desc" value="&lt;div&gt;&lt;b&gt;API calls&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;api.domain hits the Application Load Balancer (HTTPS via ACM) in the public subnet.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="s3-grp" vertex="1">
