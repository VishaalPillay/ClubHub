                <mxCell id="s11-desc" value="&lt;div&gt;&lt;b&gt;Roll out the new API&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;ECS pulls the new image and replaces the task; migrations run on boot before it serves traffic.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="s11-grp" vertex="1">
