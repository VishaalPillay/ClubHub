                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="s6-desc" value="&lt;div&gt;&lt;b&gt;Read secrets&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;At boot the task pulls JWT secret + DB credentials from Secrets Manager — nothing secret in the image.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="s6-grp" vertex="1">
